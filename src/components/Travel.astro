---
import { feature } from 'topojson-client'
import { geoAzimuthalEqualArea, geoGraticule, geoPath } from 'd3-geo'
// @ts-expect-error - world-atlas has no bundled types
import worldData from 'world-atlas/countries-50m.json'

// ISO 3166-1 numeric codes for visited countries
const visited = new Set([
    8,   // Albania
    40,  // Austria
    203, // Czech Republic
    208, // Denmark
    250, // France
    276, // Germany
    348, // Hungary
    380, // Italy
    528, // Netherlands
    620, // Portugal
    705, // Slovenia
    724, // Spain
    752, // Sweden
])

const W = 800
const H = 490

const projection = geoAzimuthalEqualArea()
    .rotate([-20.0, -52.0, 0])
    .scale(700)
    .translate([W / 2, H / 2])

const pathGen = geoPath(projection)
// @ts-expect-error
const countries = feature(worldData, worldData.objects.countries)
const graticulePath = pathGen(geoGraticule()())

const countryPaths = countries.features
    .map((f: any) => ({ d: pathGen(f), isVisited: visited.has(Number(f.id)) }))
    .filter((p: any) => p.d !== null)
---

<section id="travel" class="py-24 border-t border-zinc-900 scroll-mt-14">
    <div class="max-w-5xl mx-auto px-6">
        <p class="text-teal-400 text-sm font-medium uppercase tracking-widest mb-4">Travel</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-zinc-100 mb-4">Traveling the world</h2>
        <p class="text-zinc-400 leading-relaxed mb-10 max-w-2xl">
            I dream of exploring as many countries as possible, living in different places
            throughout my life. The tech industry's remote culture makes that dream more real every
            year.
        </p>

        <div class="rounded-2xl border border-zinc-800 overflow-hidden bg-zinc-900/40 p-4">
            <svg
                viewBox={`0 0 ${W} ${H}`}
                xmlns="http://www.w3.org/2000/svg"
                class="w-full"
            >
                <path d={graticulePath ?? ''} fill="none" stroke="#52525b70" stroke-width="0.5" />
                {
                    countryPaths.map(({ d, isVisited }: any) => (
                        <path
                            d={d}
                            fill={isVisited ? '#14b8a6' : '#3f3f46'}
                            stroke="#09090b"
                            stroke-width="0.5"
                        />
                    ))
                }
            </svg>
        </div>
    </div>
</section>
