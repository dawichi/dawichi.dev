---
import '../styles/global.css'
import Nav from '../components/Nav.astro'

interface Props {
    title: string
    description?: string
}

const {
    title,
    description = 'Software engineer with 4+ years of experience building full-stack applications. TypeScript, NestJS, Svelte, React.',
} = Astro.props
const canonicalURL = 'https://dawichi.dev'
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />

        <title>dawichi | {title}</title>
        <meta name="title" content="dawichi | software engineer" />
        <meta name="description" content={description} />

        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content="dawichi | software engineer" />
        <meta property="og:description" content={description} />

        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={canonicalURL} />
        <meta property="twitter:title" content="dawichi | software engineer" />
        <meta property="twitter:description" content={description} />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto+Mono:wght@600&display=swap"
            rel="stylesheet"
        />
    </head>
    <body class="bg-[#09090b] text-zinc-100 antialiased">
        <Nav />
        <main>
            <slot />
        </main>
        <footer class="border-t border-zinc-900 py-8 mt-24">
            <div
                class="max-w-5xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-2 text-zinc-600 text-sm"
            >
                <span>dawichi.dev &copy; {new Date().getFullYear()}</span>
                <span>Made with TypeScript and coffee</span>
            </div>
        </footer>
    </body>
</html>
